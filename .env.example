# ── Backend ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
OUTPUTS_DIR=outputs
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: personal, image-specific observations via Claude vision.
# Pipeline degrades gracefully (skips this step) if left unset.
ANTHROPIC_API_KEY=
ANTHROPIC_OBSERVATIONS_MODEL=claude-sonnet-5

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Must be prefixed NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
